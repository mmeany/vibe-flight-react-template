# Dev-only sample. Production uses dist/.htaccess generated by build.sh.

DirectoryIndex index.html

RewriteEngine On
RewriteBase /todo/

RewriteRule ^index\.html$ /todo/ [R=301,L]

RewriteRule ^api/ index.php [L,QSA]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.html [L]
