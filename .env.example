# Copy to .env at repo root for local dev, or to dist/.env on the server. Never commit .env.

APP_ENV=production

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name

JWT_SECRET=change_me_use_openssl_rand_hex_32
JWT_EXPIRATION_DAYS=30

REGISTRATION_ENABLED=false

# Comma-separated usernames allowed to manage users and submissions via admin API
ADMIN_USERNAMES=mark

LOG_DIR=logs
LOG_LEVEL=ERROR

# HMAC secret for signed math-challenge tokens (openssl rand -hex 32)
CHALLENGE_SECRET=change_me_use_openssl_rand_hex_32

# SMTP — use Mailpit locally: host 127.0.0.1, port 1025, SMTP_SECURE=none
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=none
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Flight React App
SMTP_AUTH=

# Comma-separated origins for CORS (include Vite dev server in development)
CORS_ORIGINS=http://localhost:5173

# Frontend build-time vars (Vite reads from repo root via envDir)
VITE_GA_MEASUREMENT_ID=
VITE_SITE_URL=http://localhost:5173
