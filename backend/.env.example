# Copy to dist/.env on the server (or backend/.env for local dev). Never commit .env.

APP_ENV=production

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name

JWT_SECRET=change_me_use_openssl_rand_hex_32
JWT_EXPIRATION_DAYS=30

REGISTRATION_ENABLED=false

# Comma-separated usernames allowed to manage users via /admin/users API
ADMIN_USERNAMES=mark

LOG_DIR=../../logs
LOG_LEVEL=ERROR
